# BriefEngine Configuration

# Required: OpenAI API Key
OPENAI_API_KEY=

# Optional: Model overrides (defaults shown)
DEFAULT_MODEL=gpt-4o-mini
WRITER_MODEL=gpt-4o
EDITOR_MODEL=gpt-4odd

# Optional: Output directory
OUTPUT_DIR=outputs

# Optional: Storage
DATABASE_PATH=storage/briefengine.db

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: Max retries for API calls
MAX_RETRIES=3

# Web research (optional, recommended for citations)
ENABLE_WEB_RESEARCH=1
WEB_RESEARCH_MAX_RESULTS=5
WEB_RESEARCH_FETCH_TOP_N=3
WEB_RESEARCH_MAX_CHARS_PER_SOURCE=8000
WEB_RESEARCH_TIMEOUT_SECONDS=12

# Quality guardrails
QUALITY_STRICT_MODE=0
QUALITY_AUTO_REPAIR=1
QUALITY_MIN_CITATIONS=2
QUALITY_MIN_FAQS=4

# AI visibility / JSON-LD
AI_VISIBILITY_ENABLE=1
AI_VISIBILITY_INCLUDE_JSONLD=1
